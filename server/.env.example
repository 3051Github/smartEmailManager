# ---- Server ----
PORT=3001
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# ---- Database ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=smart_email_manager

# ---- JWT ----
JWT_SECRET=cambia_questo_segreto_con_una_stringa_lunga_e_casuale
JWT_EXPIRES_IN=7d

# ---- Crypto (AES-256 per credenziali email) ----
CRYPTO_KEY=32_caratteri_esatti_di_chiave_aes

# ---- Brevo (email di sistema: verifica account, reset password) ----
# API key: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_SENDER_NAME=Smart Email Manager
BREVO_SENDER_EMAIL=noreply@tuodominio.com
APP_URL=http://localhost:5173

# ---- OAuth Google ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ---- OAuth Facebook ----
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/auth/facebook/callback

# ---- OAuth Apple ----
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:3001/api/auth/apple/callback
